{
  "Logging": {
    "Enabled": true,
    "Application": {
      "ApplicationName": "Zamin X Logging Sample",
      "ServiceName": "Logging.WebApiSample",
      "ServiceVersion": "1.0.0"
    },
    "Sinks": {
      "Console": {
        "Enabled": true
      },
      "File": {
        "Enabled": true,
        "Path": "logs/sample-.txt",
        "RollingInterval": "Day",
        "Shared": true,
        "RetainedFileCountLimit": 14
      },
      "Seq": {
        "Enabled": false,
        "ServerUrl": "http://localhost:5341"
      }
    },
    "Enrichers": {
      "UseMachineName": true,
      "UseEnvironmentName": true,
      "UseThreadId": false,
      "CorrelationId": {
        "Enabled": true,
        "HeaderName": "X-Correlation-ID",
        "PropertyName": "CorrelationId",
        "GenerateIfMissing": true,
        "AddToResponseHeaders": true
      },
      "Trace": {
        "Enabled": true,
        "TraceIdPropertyName": "TraceId",
        "SpanIdPropertyName": "SpanId"
      }
    },
    "RequestLogging": {
      "Enabled": true,
      "MessageTemplate": "HTTP {RequestMethod} {RequestPath} responded {StatusCode} in {Elapsed:0.0000} ms",
      "IncludeQueryString": true
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
