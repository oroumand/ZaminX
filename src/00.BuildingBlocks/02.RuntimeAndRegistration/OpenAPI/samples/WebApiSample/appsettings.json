{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "OpenApi": {
    "Enabled": true,
    "DefaultDocumentName": "v1",
    "DocumentPath": "/openapi/{documentName}.json",
    "Scalar": {
      "Enabled": true,
      "RoutePrefix": "/scalar",
      "Title": "Lumen Sample"
    },
    "Swagger": {
      "Enabled": true,
      "RoutePrefix": "swagger",
      "DocumentTitle": "Swagger UI",
      "EndpointName": "Lumen OpenAPI"
    },
    "Redoc": {
      "Enabled": true,
      "RoutePrefix": "redoc",
      "DocumentTitle": "ReDoc"
    }
  }
}
